APP_NAME=Cloudflare DNS Failover
APP_ENV=production
SECRET_KEY=change-me-to-a-long-random-secret
APP_ENCRYPTION_KEY=change-me-32-byte-url-safe-base64-fernet-key
DATABASE_URL=sqlite:////data/app.db
CORS_ORIGINS=http://localhost:8080,http://localhost:5173
CHECK_INTERVAL_SECONDS=30
CHECK_TIMEOUT_SECONDS=3
FAIL_THRESHOLD=3
RECOVERY_THRESHOLD=2

# Optional: when Cloudflare Access is enabled, set both to cryptographically verify
# the Access JWT. Leave empty to fall back to the (spoofable) header-presence check.
# CLOUDFLARE_ACCESS_TEAM_DOMAIN=your-team.cloudflareaccess.com
# CLOUDFLARE_ACCESS_AUD=your-access-application-aud-tag

